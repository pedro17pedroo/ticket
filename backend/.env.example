# Configuração do Servidor - PRODUÇÃO
NODE_ENV=development
PORT=4003

# Logging - PRODUÇÃO
# info = apenas informações importantes
# warn = apenas avisos e erros
# error = apenas erros
#LOG_LEVEL=error
#DEBUG=true

# CORS
#CORS_ORIGIN=https://tdesk.tatusolutions.com,https://tdesk-organizacao.tatusolutions.com,https://tdesk-cliente.tatusolutions.com,https://tdesk-backoffice.tatusolutions.com,https://tdesk-backend.tatus>
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:4003


# PostgreSQL (Banco de dados principal para negócio)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tatuticket
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MongoDB (Banco de dados secundário para logs e auditoria)
MONGODB_URI=mongodb://localhost:27017/tatuticket_logs

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Redis (Cache e Sessões)
REDIS_HOST=localhost
REDIS_PORT=6379

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.titan.email
SMTP_PORT=587          # usa STARTTLS
SMTP_SECURE=false      # true só se usar porta 465
SMTP_USER=noreply@tatusolutions.com
SMTP_PASS=Tatu2025*E
SMTP_FROM=noreply@tatusolutions.com
SMTP_FROM_NAME=T-Desk Sistema


IMAP_HOST=imap.titan.email
IMAP_PORT=993
IMAP_USER=noreply@tatusolutions.com
IMAP_PASS=Tatu2025*E


# Upload Configuration
MAX_FILE_SIZE=20971520
UPLOAD_DIR=uploads/

# Rate Limiting
RATE_LIMIT_WINDOW_MS=999999999999999999999
RATE_LIMIT_MAX_REQUESTS=999999999999999999999

# Frontend URLs (para links nos emails)
FRONTEND_URL=http://localhost:5173
CLIENT_PORTAL_URL=http://localhost:5174
ORGANIZATION_PORTAL_URL=http://localhost:5173

# Organização Single-Tenant (Configuração inicial)
DEFAULT_ORG_NAME=Empresa Demo
DEFAULT_ORG_SLUG=empresa-demo

# Payment Gateway - TPagamento (Angola)
TPAGAMENTO_API_URL=https://tpagamento-backend.tatusolutions.com/api/v1
TPAGAMENTO_API_KEY=pk_test_ttb_sandbox_key
TPAGAMENTO_WEBHOOK_SECRET=your-webhook-secret
