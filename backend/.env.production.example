# Configuração do Servidor - PRODUÇÃO
NODE_ENV=production
PORT=4003

# Logging - PRODUÇÃO
# info = apenas informações importantes
# warn = apenas avisos e erros
# error = apenas erros
LOG_LEVEL=info
DEBUG=false

# CORS - PRODUÇÃO
CORS_ORIGIN=https://tdesk.tatusolutions.com,https://tdesk-organizacao.tatusolutions.com,https://tdesk-cliente.tatusolutions.com,https://tdesk-backoffice.tatusolutions.com

# PostgreSQL (Banco de dados principal para negócio)
POSTGRES_HOST=your-production-db-host
POSTGRES_PORT=5432
POSTGRES_DB=tatuticket_prod
POSTGRES_USER=your-db-user
POSTGRES_PASSWORD="your-secure-password"

# MongoDB (Banco de dados secundário para logs e auditoria)
MONGODB_URI=mongodb://your-mongo-host:27017/tdesk_logs_prod

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-CHANGE-THIS-IN-PRODUCTION

# Redis
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@domain.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@tatusolutions.com

# IMAP (Email Inbox)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@domain.com
IMAP_PASSWORD=your-app-password
IMAP_TLS=true

# URLs Frontend
FRONTEND_URL=https://tdesk.tatusolutions.com
ORGANIZATION_PORTAL_URL=https://tdesk-organizacao.tatusolutions.com
CLIENT_PORTAL_URL=https://tdesk-cliente.tatusolutions.com
BACKOFFICE_PORTAL_URL=https://tdesk-backoffice.tatusolutions.com

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Session
SESSION_SECRET=your-session-secret-CHANGE-THIS

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
